APP_NAME=BeeCount Cloud
APP_ENV=development
API_PREFIX=/api/v1
DATABASE_URL=sqlite:///./beecount.db
JWT_SECRET=change-me-in-production-at-least-32-bytes
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
CORS_ORIGINS=http://localhost:8080,http://localhost:5173,http://localhost:3000
WEB_STATIC_DIR=/app/static
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=30
BACKUP_STORAGE_DIR=./data/backups
BACKUP_MAX_UPLOAD_BYTES=67108864
ALLOW_APP_RW_SCOPES=true

# ===== AI 文档 Q&A(可选)=====
# 配了就启用 ⌘K 「问 AI」(对 BeeCount-Website 的文档做 RAG)。
# 不配也行,用户点「问 AI」时 fallback 到「跳官网搜文档」。
#
# 默认走 SiliconFlow + BAAI/bge-m3,免费 quota cover 几十万次问答。
# 注册 https://siliconflow.cn 拿 key 填进来即可。
#
# 关键约束:EMBEDDING_MODEL 必须跟 BeeCount-Website 索引 build 时一致
# (docker image 自带的 sqlite 默认是 BAAI/bge-m3 build 的)。换 model
# 必须双侧同步,见 .docs/web-cmdk-ai-doc-search.md。
#
# 兼容的 provider:
#   - SiliconFlow(默认):https://api.siliconflow.cn/v1, BAAI/bge-m3 (1024)
#   - OpenAI:           https://api.openai.com/v1, text-embedding-3-small (1536)
#   - 智谱:             https://open.bigmodel.cn/api/paas/v4, embedding-3 (2048)
#   - 阿里灵积:         https://dashscope.aliyuncs.com/compatible-mode/v1, text-embedding-v3 (1024)
#   - 火山方舟:         https://ark.cn-beijing.volces.com/api/v3, doubao-embedding (2048)
#   - Voyage:           https://api.voyageai.com/v1, voyage-3 (1024)
#   - Mistral:          https://api.mistral.ai/v1, mistral-embed (1024)
#   - Jina:             https://api.jina.ai/v1, jina-embeddings-v3 (1024)
#   - Together AI:      https://api.together.xyz/v1, BAAI/bge-large-en-v1.5 (1024)
#   - Ollama 本地:      http://localhost:11434/v1, bge-m3 (1024)— 完全离线
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_API_KEY=

# ===== 汇率代理(多币种 MVP)=====
EXCHANGE_RATE_PROXY_ENABLED=true
EXCHANGE_RATE_CACHE_TTL_HOURS=12
# 可选:整体替换上游为自托管 Frankfurter(http://host:8080)
EXCHANGE_RATE_UPSTREAM=
